{
  "name": "jjkccmodmanager",
  "productName": "JJK CC Mod Manager",
  "version": "0.1.0",
  "description": "Mod Manager App for Jujutsu Kaisen CC",
  "main": "main.js",
  "scripts": {
    "postinstall": "npm --prefix ./AssetRegistryPatcher install",
    "prestart": "npm run patcher:build",
    "patcher:build": "npm --prefix ./AssetRegistryPatcher run build",
    "start": "electron .",
    "build": "electron-builder --win --x64",
    "build:portable": "electron-builder --win portable --x64"
  },
  "build": {
    "appId": "com.jjkcc.modmanager",
    "productName": "JJKCCModManager",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "lib/**",
      "renderer/**",
      "data/**",
      "tools/**",
      "node_modules/**"
    ],
    "extraResources": [
      {
        "from": "tools",
        "to": "tools"
      },
      {
        "from": "data",
        "to": "data"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": null,
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "adm-zip": "^0.5.17"
  },
  "devDependencies": {
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1"
  }
}
